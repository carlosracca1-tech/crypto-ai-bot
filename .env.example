# ═══════════════════════════════════════════════════════════════
# AI CRYPTO BOT - Variables de entorno
# Copia este archivo a .env y rellena los valores
# ═══════════════════════════════════════════════════════════════

# ─── OpenAI ────────────────────────────────────────────────────
# REQUERIDO: Clave API de OpenAI
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo GPT a usar (gpt-4o recomendado para mayor calidad)
OPENAI_MODEL=gpt-4o

# Modelo de imagen (dall-e-3 o dall-e-2)
OPENAI_IMAGE_MODEL=dall-e-3

# Tokens máximos por respuesta
OPENAI_MAX_TOKENS=1500

# ─── Twitter / X ───────────────────────────────────────────────
# Credenciales de la app de Twitter (Developer Portal)
# https://developer.twitter.com/en/portal/dashboard

# App Key y Secret (OAuth 1.0a para posting)
TWITTER_APP_KEY=xxxxxxxxxxxxxxxxxxxxxxx
TWITTER_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Access Token y Secret (de tu cuenta de usuario)
TWITTER_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITTER_ACCESS_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bearer Token (para lectura/búsqueda de tweets - Narrative Detection)
TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── CoinGecko ─────────────────────────────────────────────────
# Opcional: API Key Pro para mayor rate limit
# Sin key usa el endpoint público (30 calls/min)
COINGECKO_API_KEY=

# Rate limit entre llamadas en ms (1500ms = ~40/min para free tier)
COINGECKO_RATE_LIMIT_MS=1500

# ─── Tokens a monitorear ───────────────────────────────────────
# IDs de CoinGecko separados por coma
# Dejar vacío para usar la lista por defecto
TOKEN_IDS=

# Top N tokens a analizar en profundidad
TOKEN_TOP_N=10

# ─── Análisis de narrativas ────────────────────────────────────
# Tweets a buscar por query
NARRATIVE_TWEETS_PER_QUERY=50

# Mínimo de menciones para considerar un término relevante
NARRATIVE_MIN_MENTIONS=3

# Ventana temporal de análisis en horas
NARRATIVE_LOOKBACK_HOURS=24

# ─── Contenido ─────────────────────────────────────────────────
# Número de tweets a publicar por día
TWEETS_PER_DAY=3

# Frecuencia del thread (cada N días)
THREAD_EVERY_N_DAYS=3

# DRY RUN: true = no publica nada (solo genera y loguea)
DRY_RUN=false

# MANUAL APPROVAL: true = requiere aprobación manual antes de publicar
# Usar: npm run review
MANUAL_APPROVAL=false

# ─── Imágenes ──────────────────────────────────────────────────
# Directorio de salida para imágenes generadas
IMAGE_OUTPUT_DIR=./data/images

# Usar OpenAI para generar imágenes (más creativo pero más costoso)
USE_OPENAI_IMAGES=false

# ─── Storage ───────────────────────────────────────────────────
DATA_DIR=./data

# ─── Scheduler ─────────────────────────────────────────────────
# Expresión cron para ejecución (UTC)
# '0 6 * * *' = 06:00 UTC diariamente
# '0 9,14,19 * * *' = 09:00, 14:00, 19:00 UTC
CRON_SCHEDULE=0 6 * * *

# ─── Sistema ───────────────────────────────────────────────────
# Nivel de logging: error, warn, info, debug
LOG_LEVEL=info

# Número máximo de reintentos para APIs
MAX_RETRIES=3

# Delay base entre reintentos en ms
RETRY_DELAY_MS=2000

# NODE_ENV
NODE_ENV=production
